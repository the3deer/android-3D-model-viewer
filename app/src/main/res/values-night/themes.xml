<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark Theme (Night) matches the professional engine look -->
    <style name="Theme.AndroidModelViewer" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color (Toolbar/Status Bar) -->
        <item name="colorPrimary">@color/engine_dark_grey</item>
        <item name="colorPrimaryVariant">@color/black</item>
        <item name="colorOnPrimary">@color/engine_text_primary</item>

        <!-- Secondary brand color (Accent/Highlights) -->
        <item name="colorSecondary">@color/engine_accent</item>
        <item name="colorSecondaryVariant">@color/engine_accent_variant</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Navigation Drawer Style -->
        <item name="android:windowBackground">@color/engine_dark_grey</item>
    </style>
</resources>